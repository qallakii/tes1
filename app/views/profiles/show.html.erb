<div class="dashboard-page">
  <div class="drive-page-head">
    <div class="drive-head-left">
      <div class="profile-page-title">
        <h2>Profile</h2>
        <p>Manage your personal account details and sign-in information.</p>
      </div>
    </div>
    <div class="drive-head-right">
      <%= link_to "Edit profile", edit_profile_path, class: "btn secondary" %>
    </div>
  </div>

  <div class="drive-card profile-card">
    <div class="profile-summary">
      <div class="profile-avatar-large"><%= @user.first_name[0].upcase %></div>
      <div>
        <h3><%= @user.name %></h3>
        <p><%= @user.email %></p>
      </div>
    </div>

    <div class="profile-grid">
      <div class="profile-field">
        <span class="profile-label">Full name</span>
        <strong><%= @user.name %></strong>
      </div>
      <div class="profile-field">
        <span class="profile-label">Email address</span>
        <strong><%= @user.email %></strong>
      </div>
      <div class="profile-field">
        <span class="profile-label">Role</span>
        <strong><%= @user.admin? ? "Admin" : "User" %></strong>
      </div>
      <div class="profile-field">
        <span class="profile-label">Password</span>
        <strong>Hidden for security</strong>
      </div>
    </div>

    <div class="profile-note">
      Use the edit screen to change your name, email address, or password.
    </div>
  </div>
</div>
