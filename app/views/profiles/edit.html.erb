<div class="dashboard-page">
  <div class="drive-page-head">
    <div class="drive-head-left">
      <div class="profile-page-title">
        <h2>Edit Profile</h2>
        <p>Update your account details. Leave the password fields blank to keep your current password.</p>
      </div>
    </div>
    <div class="drive-head-right">
      <%= link_to "Back", profile_path, class: "btn secondary" %>
    </div>
  </div>

  <div class="drive-card profile-card">
    <%= form_with model: @user, url: profile_path, method: :patch, local: true do |f| %>
      <div class="profile-form-grid">
        <div class="profile-form-field">
          <%= f.label :name %>
          <%= f.text_field :name, class: "drive-input profile-input", autocomplete: "name" %>
        </div>

        <div class="profile-form-field">
          <%= f.label :email %>
          <%= f.email_field :email, class: "drive-input profile-input", autocomplete: "email" %>
        </div>

        <div class="profile-password-panel">
          <div class="profile-password-title">Change password</div>
          <div class="profile-password-copy">Use a new password only if you want to replace the current one.</div>

          <div class="profile-password-grid">
            <div class="profile-form-field">
              <%= f.label :password %>
              <%= f.password_field :password, class: "drive-input profile-input", autocomplete: "new-password" %>
            </div>
            <div class="profile-form-field">
              <%= f.label :password_confirmation %>
              <%= f.password_field :password_confirmation, class: "drive-input profile-input", autocomplete: "new-password" %>
            </div>
          </div>
        </div>

        <div class="profile-actions">
          <%= f.submit "Save changes", class: "btn primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
