<div class="dashboard-page">
  <div class="drive-page-head">
    <div class="drive-head-left">
      <div>
        <h2>Upload file</h2>
        <div class="muted">Add a file to <%= @folder.name %>.</div>
      </div>
    </div>

    <div class="drive-head-right">
      <%= link_to "Back", folder_path(@folder), class: "btn secondary" %>
    </div>
  </div>

  <div class="drive-card">
    <%= form_with url: folder_cvs_path(@folder), method: :post, local: true, html: { multipart: true }, class: "profile-form" do |form| %>
      <% if @cv.errors.any? %>
        <div class="flash alert">
          <%= @cv.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div class="field">
        <%= form.label :files, "File" %>
        <%= file_field_tag "cv[files][]", required: true, class: "drive-input" %>
      </div>

      <div class="modal-actions">
        <%= link_to "Cancel", folder_path(@folder), class: "btn secondary" %>
        <%= form.submit "Upload", class: "btn primary" %>
      </div>
    <% end %>
  </div>
</div>
