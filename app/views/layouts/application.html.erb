<!DOCTYPE html>
<html>
  <head>
    <title>CV Share</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% auth_pages = controller_name.in?(%w[sessions users home]) %>

    <% public_share_page = (controller_name == "share_links" && action_name == "show") %>
    <% if !auth_pages && (current_user || public_share_page) %>
      <div class="drive-shell">

        <!-- Top bar -->
        <header class="drive-topbar">
          <div class="drive-top-left">
            <%= link_to (current_user ? dashboard_path : root_path), class: "drive-logo" do %>
              <%= image_tag "image.png", alt: "Logo", class: "app-logo" %>
            <% end %>
          </div>



          <div class="drive-top-center">
            <div class="drive-searchbar">
              <span class="drive-search-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="7"></circle>
                  <path d="M21 21l-4.3-4.3"></path>
                </svg>
              </span>

              <!-- ✅ REAL GLOBAL SEARCH -->
              <%= form_with url: search_path, method: :get, local: true, class: "drive-search-form" do %>
                <%= text_field_tag :q, params[:q], placeholder: "Search in CV Share", class: "drive-search-input" %>
              <% end %>
            </div>
          </div>

          <div class="drive-top-right">
            <% if current_user %>
              <div class="user-dropdown">
                <button id="profileBtn" class="profile-toggle" type="button">
                  <div class="avatar"><%= current_user.first_name[0].upcase %></div>
                  <span class="profile-name"><%= current_user.first_name.capitalize %></span>
                </button>

                <ul id="profileMenu" class="dropdown-menu hidden">
                  <li class="dropdown-user-meta">
                    <div class="dropdown-user-name"><%= current_user.name %></div>
                    <div class="dropdown-user-email"><%= current_user.email %></div>
                  </li>
                  <li><%= link_to "View profile", profile_path %></li>
                  <li><%= link_to "Edit profile", edit_profile_path %></li>
                  <li><%= link_to "Logout", logout_path, data: { turbo_method: :delete }, class: "dropdown-danger" %></li>
                </ul>
              </div>
            <% else %>
              <%= link_to "Login", login_path, class: "btn secondary" %>
            <% end %>
          </div>

        </header>

        <div class="drive-body <%= 'no-sidebar' unless current_user %>">
            <%if current_user %>
              <!-- Sidebar -->
              <aside class="drive-sidebar">
                <div class="drive-side-section">
                  <%= link_to dashboard_path, class: "drive-side-link #{'active' if controller_name == 'folders' && action_name == 'index'}" do %>
                    <span class="drive-side-ic" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 10.5L12 3l9 7.5V21a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1z"></path>
                      </svg>
                    </span>
                    <span>Home</span>
                  <% end %>

                  <%= link_to recents_path, class: "drive-side-link #{'active' if controller_name == 'recents'}" do %>
                    <span class="drive-side-ic" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 8v5l3 2"></path>
                        <circle cx="12" cy="12" r="9"></circle>
                      </svg>
                    </span>
                    <span>Recents</span>
                  <% end %>

                  <%= link_to share_links_path, class: "drive-side-link #{'active' if controller_name == 'share_links'}" do %>
                    <span class="drive-side-ic" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10 13a5 5 0 0 1 0-7l1-1a5 5 0 0 1 7 7l-1 1"></path>
                        <path d="M14 11a5 5 0 0 1 0 7l-1 1a5 5 0 0 1-7-7l1-1"></path>
                      </svg>
                    </span>
                    <span>Shared Links</span>
                  <% end %>

                  <%= link_to shared_with_me_path, class: "drive-side-link #{'active' if controller_name == 'shared_with_me'}" do %>
                    <span class="drive-side-ic" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                      </svg>
                    </span>
                    <span>Shared With Me</span>
                  <% end %>

                  <%= link_to profile_path, class: "drive-side-link #{'active' if controller_name == 'profiles'}" do %>
                    <span class="drive-side-ic" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21a8 8 0 0 0-16 0"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                      </svg>
                    </span>
                    <span>Profile</span>
                  <% end %>

                  <% if current_user&.admin? %>
                    <%= link_to admin_root_path, class: "drive-side-link #{'active' if controller_path.start_with?('admin/')}" do %>
                      <span class="drive-side-ic" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z"></path>
                          <path d="M9.5 12.5l1.5 1.5 3.5-4"></path>
                        </svg>
                      </span>
                      <span>Admin</span>
                    <% end %>
                  <% end %>
                </div>
              </aside>
            <% end %>

              <!-- Main content -->
          <main class="drive-main">
            <% if flash[:notice] %>
              <p class="flash notice" data-auto-dismiss="3000"><%= flash[:notice] %></p>
            <% end %>

            <% if flash[:alert] %>
              <p class="flash alert" data-auto-dismiss="3000"><%= flash[:alert] %></p>
            <% end %>

            <% if flash[:share_url] %>
              <div class="share-result-banner">
                <div class="share-result-copy">
                  <div class="share-result-title">Share link</div>
                  <a class="share-result-url" href="<%= flash[:share_url] %>" target="_blank" rel="noopener"><%= flash[:share_url] %></a>
                </div>
                <button type="button" class="btn secondary xsmall" data-copy="<%= flash[:share_url] %>">Copy</button>
              </div>
            <% end %>

            <% if flash[:admin_action_url] %>
              <div class="share-result-banner">
                <div class="share-result-copy">
                  <div class="share-result-title"><%= flash[:admin_action_title].presence || "Generated link" %></div>
                  <a class="share-result-url" href="<%= flash[:admin_action_url] %>" target="_blank" rel="noopener"><%= flash[:admin_action_url] %></a>
                </div>
                <button type="button" class="btn secondary xsmall" data-copy="<%= flash[:admin_action_url] %>">Copy</button>
              </div>
            <% end %>

            <%= yield %>
          </main>
        </div>

        <%= render "shared/footer" %>
      </div>

    <% else %>
      <%# auth pages / public pages keep simple %>

      <% if flash[:notice] %>
        <p class="flash notice" data-auto-dismiss="3000"><%= flash[:notice] %></p>
      <% end %>

      <% if flash[:alert] %>
        <p class="flash alert" data-auto-dismiss="3000"><%= flash[:alert] %></p>
      <% end %>

      <% if flash[:share_url] %>
        <div class="share-result-banner">
          <div class="share-result-copy">
            <div class="share-result-title">Share link</div>
            <a class="share-result-url" href="<%= flash[:share_url] %>" target="_blank" rel="noopener"><%= flash[:share_url] %></a>
          </div>
          <button type="button" class="btn secondary xsmall" data-copy="<%= flash[:share_url] %>">Copy</button>
        </div>
      <% end %>

      <% if flash[:admin_action_url] %>
        <div class="share-result-banner">
          <div class="share-result-copy">
            <div class="share-result-title"><%= flash[:admin_action_title].presence || "Generated link" %></div>
            <a class="share-result-url" href="<%= flash[:admin_action_url] %>" target="_blank" rel="noopener"><%= flash[:admin_action_url] %></a>
          </div>
          <button type="button" class="btn secondary xsmall" data-copy="<%= flash[:admin_action_url] %>">Copy</button>
        </div>
      <% end %>

      <%= yield %>

      <%= render "shared/footer" %>
    <% end %>

    
  </body>
</html>
