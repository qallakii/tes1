<div class="dashboard-page" data-shared-with-me>
  <div class="drive-page-head">
    <div class="drive-head-main">
      <div class="drive-head-left">
        <div>
          <div class="shared-with-me-kicker">Recipient View</div>
          <h1 class="shared-with-me-title">Shared With Me</h1>
          <div class="muted shared-with-me-subtitle">Folders and files other users explicitly shared with your account.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="shared-section-head">
    <h2>Items</h2>
    <span class="shared-count"><%= @shared_entries.size %></span>
  </div>

  <% if @shared_entries.any? %>
    <div class="drive-card">
      <div class="drive-scroll">
        <div class="drive-list shared-items-list">
          <div class="drive-header">
            <div class="col-item-name">Name</div>
            <div class="col-item-type">Type</div>
            <div class="col-item-owner">Shared by</div>
            <div class="col-item-permission">Permission</div>
            <div class="col-item-expiry">Expires</div>
            <div class="col-item-actions">Actions</div>
          </div>

          <% @shared_entries.each do |entry| %>
            <% is_folder = entry.item_type == :folder %>
            <% item_name = is_folder ? entry.folder.name : (entry.cv.title.presence || entry.cv.file.filename.to_s) %>
            <% open_url = is_folder ? public_share_path(entry.share_link.token, folder_id: entry.folder.id) : share_link_file_preview_path(entry.share_link, cv_id: entry.cv.id) %>
            <div class="drive-row shared-item-row" data-open-url="<%= open_url %>">
              <div class="col-item-name">
                <a href="<%= open_url %>" class="folder-link">
                  <span class="folder-icon" aria-hidden="true">
                    <% if is_folder %>
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 7a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                      </svg>
                    <% else %>
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <path d="M14 2v6h6"></path>
                      </svg>
                    <% end %>
                  </span>
                  <span class="folder-name"><%= item_name %></span>
                </a>
              </div>

              <div class="col-item-type">
                <span class="shared-type-badge <%= is_folder ? 'is-folder' : 'is-file' %>"><%= is_folder ? "Folder" : "File" %></span>
              </div>

              <div class="col-item-owner">
                <span class="muted"><%= entry.sender&.email || "Unknown sender" %></span>
              </div>

              <div class="col-item-permission">
                <span class="shared-permission-badge <%= entry.permission == "editor" ? "is-editor" : "is-viewer" %>">
                  <%= entry.permission == "editor" ? "Can edit" : "Can view" %>
                </span>
              </div>

              <div class="col-item-expiry">
                <span class="muted">
                  <% if entry.share_link.expires_at.nil? %>
                    Never
                  <% elsif entry.share_link.expires_at < Time.current %>
                    Expired
                  <% else %>
                    <%= entry.share_link.expires_at.strftime("%b %d, %Y %H:%M") %>
                  <% end %>
                </span>
              </div>

              <div class="col-item-actions">
                <div class="action-group">
                  <% if is_folder %>
                    <%= link_to "Open",
                      open_url,
                      class: "btn secondary xsmall" %>
                  <% else %>
                    <%= link_to "Open",
                      open_url,
                      target: "_blank",
                      rel: "noopener",
                      class: "btn secondary xsmall" %>
                    <%= link_to "Download",
                      share_link_file_download_path(entry.share_link, cv_id: entry.cv.id),
                      class: "btn secondary xsmall" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="drive-card shared-empty-card">
      <div class="muted">Nothing has been shared with you yet.</div>
    </div>
  <% end %>
</div>
