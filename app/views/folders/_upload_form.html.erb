<!-- Upload modal -->
  <div id="upload-overlay" class="overlay" style="display:none;">
    <div class="modal-card upload-modal-card">
      <div class="modal-head">
        <h3 class="modal-title">Upload files</h3>
        <button type="button" id="close-upload" class="btn secondary xsmall">Close</button>
      </div>

      <div class="muted modal-copy">
        Drag & drop files here, or click “Choose files”.
      </div>

      <%= form_with url: folder_cvs_path(@folder), method: :post, local: true, html: { multipart: true }, id: "upload-form" do %>
        <div id="upload-dropzone" class="upload-dropzone upload-dropzone-spaced">
          <div class="upload-dropzone-inner">
            <div class="upload-dropzone-title">Drop files or a folder to upload</div>
            <div class="muted upload-dropzone-subtitle">or</div>

            <div class="upload-dropzone-actions">
              <button type="button" id="choose-files" class="btn secondary">
                Choose files
              </button>

              <button type="button" id="choose-folder" class="btn secondary">
                Choose folder
              </button>
            </div>

            <input id="upload-file-input" type="file" name="cv[files][]" multiple hidden />
            <input id="upload-folder-input" type="file" name="cv[files][]" multiple webkitdirectory directory hidden />

            <div id="upload-paths"></div>
          </div>
        </div>

        <div id="upload-file-list-wrap" class="upload-file-list-wrap" style="display:none;">
          <div class="muted upload-file-list-label">Selected</div>
          <ul id="upload-file-list" class="upload-file-list"></ul>
        </div>

        <div class="modal-actions">
          <button type="button" id="cancel-upload" class="btn secondary">Cancel</button>
          <button type="submit" id="upload-submit" class="btn primary" disabled>Upload</button>
        </div>
      <% end %>

    </div>
  </div>
