<div class="dashboard-page search-page">
  <div class="drive-page-head search-page-head">
    <div class="profile-page-title">
      <h2>Search</h2>
      <p>Find folders and files across your workspace.</p>
    </div>

    <%= form_with url: search_path, method: :get, local: true, class: "search-form" do %>
      <input class="drive-input search-form-input" type="text" name="q" value="<%= @q %>" placeholder="Search folders or files…" />
      <button class="btn primary" type="submit">Search</button>
    <% end %>
  </div>

  <% if @q.present? %>
    <div class="drive-card search-results-card">
      <div class="search-section-title">Folders</div>
      <% if @folders.any? %>
        <ul class="search-results-list">
          <% @folders.each do |f| %>
            <li><%= link_to f.name, folder_path(f), class: "search-result-link" %></li>
          <% end %>
        </ul>
      <% else %>
        <div class="muted">No folders found.</div>
      <% end %>

      <div class="search-section-spacer"></div>

      <div class="search-section-title">Files</div>
      <% if @cvs.any? %>
        <ul class="search-results-list">
          <% @cvs.each do |cv| %>
            <li>
              <%= link_to(cv.title.presence || cv.file.filename.to_s, folder_path(cv.folder), class: "search-result-link") %>
              <span class="muted">in <%= cv.folder.name %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="muted">No files found.</div>
      <% end %>
    </div>
  <% else %>
    <div class="drive-card search-results-card">
      <div class="muted">Enter a keyword to search your folders and files.</div>
    </div>
  <% end %>
</div>
