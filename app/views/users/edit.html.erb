<div class="page-head">
  <div>
    <h1 class="page-title">Settings</h1>
    <div class="page-sub">Update your profile and password.</div>
  </div>

  <div class="legacy-page-actions">
    <%= link_to "Back", profile_path, class: "btn" %>
  </div>
</div>

<div class="card card-pad legacy-page-card">
  <div class="page-sub legacy-page-subhead">Storage used: <strong><%= format_bytes(@storage_bytes) %></strong></div>

  <%= form_with(model: @user, url: profile_path, method: :patch, local: true) do |f| %>
    <div class="form-row">
      <label class="label">Name</label>
      <%= f.text_field :name, class: "input" %>
    </div>

    <div class="form-row">
      <label class="label">Email</label>
      <%= f.email_field :email, class: "input" %>
    </div>

    <div class="form-row">
      <label class="label">New password (optional)</label>
      <%= f.password_field :password, class: "input", autocomplete: "new-password" %>
    </div>

    <div class="form-row">
      <label class="label">Confirm new password</label>
      <%= f.password_field :password_confirmation, class: "input", autocomplete: "new-password" %>
    </div>

    <div class="legacy-page-actions">
      <%= f.submit "Save changes", class: "btn primary" %>
      <%= link_to "Cancel", profile_path, class: "btn" %>
    </div>
  <% end %>
</div>
