<div class="dashboard-page share-access-page">
  <div class="drive-card share-access-card">
    <div class="profile-page-title">
      <h2>Password Required</h2>
      <p>This share link is protected. Enter the password to continue.</p>
    </div>

    <% if flash[:alert].present? %>
      <div class="share-access-error"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: unlock_share_link_path(@share_link.token), method: :post, local: true, class: "share-access-form" do %>
      <div class="profile-form-field">
        <label for="share-link-password">Password</label>
        <input id="share-link-password" type="password" name="password" required class="drive-input share-access-input">
      </div>

      <div class="share-access-actions">
        <button class="btn primary" type="submit">Unlock</button>
      </div>
    <% end %>
  </div>
</div>
