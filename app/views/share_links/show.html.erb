<div class="dashboard-page">

  <% share_url = public_share_url(@share_link.token) %>
  <% folders = (@folders.presence || []).to_a %>
  <% selected_folder = @folder %>
  <% direct_files = defined?(@direct_cvs) ? (@direct_cvs || []) : [] %>

  <div class="drive-page-head">
    <div class="drive-head-left folder-show-head-left">
      <% if selected_folder && !@files_only %>
        <%= link_to "← Back", public_share_path(@share_link.token), class: "btn secondary" %>
      <% end %>

      <div>
        <h2 class="folder-show-title">
          <% if @files_only %>
            Shared files
          <% elsif selected_folder %>
            <%= selected_folder.name %>
          <% else %>
            Shared folders
          <% end %>
        </h2>

        <div class="muted folder-show-breadcrumbs">
          <% if selected_folder && !@files_only %>
            <%= link_to "Shared folders", public_share_path(@share_link.token), class: "muted" %>
            <span aria-hidden="true"> / </span>
            <span><%= selected_folder.name %></span>
          <% elsif @files_only %>
            <span>Only the selected files are visible here.</span>
          <% else %>
            <span>Open a folder to view its files.</span>
          <% end %>
          <span aria-hidden="true"> · </span>
          <% if @share_link.expires_at.nil? %>
            <span>Expires: Never</span>
          <% else %>
            <span>Expires: <%= @share_link.expires_at.strftime("%b %d, %Y %H:%M") %></span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="drive-head-right folder-show-head-right">
      <!-- ✅ Bulk actions (shows only when something is selected) -->
      <div id="bulk-actions" class="folder-show-bulk-actions" style="display:none;">
        <button id="bulk-clear" class="btn secondary" type="button">Clear</button>
        <button id="bulk-open" class="btn secondary" type="button">Open</button>
        <button id="bulk-download" class="btn secondary" type="button">Download</button>
      </div>
    </div>
  </div>

  <%# ====== FOLDERS LIST (when nothing selected) ====== %>
  <% unless selected_folder || @files_only %>
    <div class="drive-card">
      <div class="drive-scroll">
        <div class="drive-list cvs-list">

          <div class="drive-header">
            <div class="col-cv-check"><input type="checkbox" id="select-all" /></div>
            <div class="col-cv-name">Name</div>
            <div class="col-cv-type">Type</div>
            <div class="col-cv-size">Size</div>
            <div class="col-cv-modified">Last modified</div>
            <div class="col-cv-actions">Actions</div>
          </div>

          <% folders.each do |f| %>
            <% open_url = public_share_path(@share_link.token, folder_id: f.id) %>
            <% download_url = @share_link.allow_download? ? folder_download_share_link_path(@share_link, folder_id: f.id) : nil %>
            <div class="drive-row folder-row clickable-folder-row"
                 data-kind="folder"
                 data-open="<%= open_url %>"
                 data-download="<%= download_url || "" %>">
              <div class="col-cv-check">
                <input class="folder-check" type="checkbox" value="<%= f.id %>" />
              </div>

              <div class="col-cv-name">
                <div class="file-line">
                  <%= folder_icon_tag %>
                  <div class="file-text">
                    <div class="file-name"><%= f.name %></div>
                    <div class="file-sub">Folder</div>
                  </div>
                </div>
              </div>

              <div class="col-cv-type"><span class="pill">FOLDER</span></div>
              <div class="col-cv-size"><span class="muted">—</span></div>
              <div class="col-cv-modified"><span class="muted"><%= f.updated_at.strftime("%b %d, %Y %H:%M") %></span></div>

              <div class="col-cv-actions">
                <div class="kebab-wrap">
                  <button type="button" class="kebab-btn" data-action-menu-trigger="true" data-menu-id="share-root-folder-actions-<%= f.id %>" aria-label="Folder actions">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                      <circle cx="12" cy="5" r="1.8"></circle>
                      <circle cx="12" cy="12" r="1.8"></circle>
                      <circle cx="12" cy="19" r="1.8"></circle>
                    </svg>
                  </button>

                  <div id="share-root-folder-actions-<%= f.id %>" class="kebab-menu hidden">
                    <%= link_to "Open", open_url, class: "kebab-item" %>
                    <% if download_url.present? %>
                      <%= link_to "Download", download_url, class: "kebab-item", data: { turbo: false, turbo_frame: "_top" } %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <% if folders.empty? %>
            <div class="muted share-empty-copy">No folders found in this share link.</div>
          <% end %>

        </div>
      </div>
    </div>
  <% end %>

  <%# ====== FILES ONLY MODE (MATCH folder/show style) ====== %>
  <% if @files_only %>
    <div class="drive-card">
      <div class="drive-scroll">
        <div class="drive-list cvs-list">

          <div class="drive-header">
            <div class="col-cv-check"><input type="checkbox" id="select-all" /></div>
            <div class="col-cv-name">Name</div>
            <div class="col-cv-type">Type</div>
            <div class="col-cv-size">Size</div>
            <div class="col-cv-modified">Last modified</div>
            <div class="col-cv-actions">Actions</div>
          </div>

          <% if (@cvs || []).any? %>
            <% (@cvs || []).each do |cv| %>
              <% blob = cv.file&.blob %>
              <% next unless blob %>

              <% display_name = cv.title.presence || cv.file.filename.to_s %>
              <% ext = cv.file.filename.extension.to_s.upcase %>
              <% type_label = ext.present? ? ext : "FILE" %>
              <% size_bytes = blob.byte_size.to_i %>
              <% content_type = blob.content_type.to_s %>

              <% preview_url  = file_preview_share_link_path(@share_link, cv_id: cv.id) %>
              <% download_url = file_download_share_link_path(@share_link, cv_id: cv.id) %>

              <div class="drive-row cv-row clickable-row"
                   data-kind="file"
                   data-preview="<%= preview_url || "" %>"
                   data-download="<%= download_url || "" %>"
                   data-preview-kind="<%= content_type %>"
                   data-preview-title="<%= display_name %>">

                <div class="col-cv-check">
                  <input class="cv-check" type="checkbox" value="<%= cv.id %>" />
                </div>

                <div class="col-cv-name">
                  <div class="file-line">
                    <%= file_icon_tag(cv.file, content_type: content_type) %>

                    <div class="file-text">
                      <div class="file-name"><%= display_name %></div>
                      <div class="file-sub"><%= cv.file.filename %></div>
                    </div>
                  </div>
                </div>

                <div class="col-cv-type"><span class="pill"><%= type_label %></span></div>
                <div class="col-cv-size"><span class="muted size-num" data-size-text><%= size_bytes %></span></div>
                <div class="col-cv-modified"><span class="muted"><%= cv.updated_at.strftime("%b %d, %Y %H:%M") %></span></div>

                <div class="col-cv-actions">
                  <div class="kebab-wrap">
                    <button type="button" class="kebab-btn" data-action-menu-trigger="true" data-menu-id="share-file-actions-<%= cv.id %>" aria-label="File actions">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                        <circle cx="12" cy="5" r="1.8"></circle>
                        <circle cx="12" cy="12" r="1.8"></circle>
                        <circle cx="12" cy="19" r="1.8"></circle>
                      </svg>
                    </button>

                    <div id="share-file-actions-<%= cv.id %>" class="kebab-menu hidden">
                    <% if @share_link.allow_preview? && preview_url.present? %>
                      <button type="button"
                              class="kebab-item share-preview-btn"
                              data-preview="<%= preview_url %>"
                              data-download="<%= download_url %>"
                              data-preview-kind="<%= content_type %>"
                              data-preview-title="<%= display_name %>">
                        Preview
                      </button>
                    <% end %>
                    <% if @share_link.allow_download? && download_url.present? %>
                      <a class="kebab-item" href="<%= download_url %>" data-turbo="false" data-turbo-frame="_top">Download</a>
                    <% end %>
                    </div>
                  </div>
                </div>

              </div>
            <% end %>
          <% else %>
            <div class="muted share-empty-copy">No files found in this share link.</div>
          <% end %>

        </div>
      </div>
    </div>
  <% end %>

  <%# ====== SELECTED FOLDER VIEW (ONE CARD, SAME GRID AS folder/show) ====== %>
  <% if selected_folder && !@files_only %>
    <div class="drive-card">
      <div class="drive-scroll">
        <div class="drive-list cvs-list">

          <div class="drive-header">
            <div class="col-cv-check"><input type="checkbox" id="select-all" /></div>
            <div class="col-cv-name">Name</div>
            <div class="col-cv-type">Type</div>
            <div class="col-cv-size">Size</div>
            <div class="col-cv-modified">Last modified</div>
            <div class="col-cv-actions">Actions</div>
          </div>

          <%# Subfolders %>
          <% (@subfolders || []).each do |sf| %>
            <% open_url = public_share_path(@share_link.token, folder_id: sf.id) %>
            <% download_url = @share_link.allow_download? ? folder_download_share_link_path(@share_link, folder_id: sf.id) : nil %>

            <div class="drive-row folder-row clickable-folder-row"
                 data-kind="folder"
                 data-open="<%= open_url %>"
                 data-download="<%= download_url || "" %>">
              <div class="col-cv-check">
                <input class="folder-check" type="checkbox" value="<%= sf.id %>" />
              </div>

              <div class="col-cv-name">
                <div class="file-line">
                  <%= folder_icon_tag %>

                  <div class="file-text">
                    <div class="file-name"><%= sf.name %></div>
                    <div class="file-sub">Folder</div>
                  </div>
                </div>
              </div>

              <div class="col-cv-type"><span class="pill">FOLDER</span></div>
              <div class="col-cv-size"><span class="muted">—</span></div>
              <div class="col-cv-modified"><span class="muted"><%= sf.updated_at.strftime("%b %d, %Y %H:%M") %></span></div>

              <div class="col-cv-actions">
                <div class="kebab-wrap">
                  <button type="button" class="kebab-btn" data-action-menu-trigger="true" data-menu-id="share-subfolder-actions-<%= sf.id %>" aria-label="Folder actions">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                      <circle cx="12" cy="5" r="1.8"></circle>
                      <circle cx="12" cy="12" r="1.8"></circle>
                      <circle cx="12" cy="19" r="1.8"></circle>
                    </svg>
                  </button>

                  <div id="share-subfolder-actions-<%= sf.id %>" class="kebab-menu hidden">
                    <%= link_to "Open", open_url, class: "kebab-item" %>
                    <% if download_url.present? %>
                      <%= link_to "Download", download_url, class: "kebab-item", data: { turbo: false, turbo_frame: "_top" } %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <%# Direct files (mixed shares) %>
          <% direct_files.each do |cv| %>
            <% blob = cv.file&.blob %>
            <% next unless blob %>

            <% display_name = cv.title.presence || cv.file.filename.to_s %>
            <% ext = cv.file.filename.extension.to_s.upcase %>
            <% type_label = ext.present? ? ext : "FILE" %>
            <% size_bytes = blob.byte_size.to_i %>
            <% content_type = blob.content_type.to_s %>

            <% preview_url  = @share_link.allow_preview?  ? file_preview_share_link_path(@share_link, cv_id: cv.id) : nil %>
            <% download_url = @share_link.allow_download? ? file_download_share_link_path(@share_link, cv_id: cv.id) : nil %>

            <div class="drive-row cv-row clickable-row"
                 data-kind="file"
                 data-preview="<%= preview_url || "" %>"
                 data-download="<%= download_url || "" %>"
                 data-preview-kind="<%= content_type %>"
                 data-preview-title="<%= display_name %>">

              <div class="col-cv-check">
                <input class="cv-check" type="checkbox" value="<%= cv.id %>" />
              </div>

              <div class="col-cv-name">
                <div class="file-line">
                  <%= file_icon_tag(cv.file, content_type: content_type) %>

                  <div class="file-text">
                    <div class="file-name"><%= display_name %></div>
                    <div class="file-sub"><%= cv.file.filename %> • Direct share</div>
                  </div>
                </div>
              </div>

              <div class="col-cv-type"><span class="pill"><%= type_label %></span></div>
              <div class="col-cv-size"><span class="muted size-num" data-size-text><%= size_bytes %></span></div>
              <div class="col-cv-modified"><span class="muted"><%= cv.updated_at.strftime("%b %d, %Y %H:%M") %></span></div>

              <div class="col-cv-actions">
                <div class="kebab-wrap">
                  <button type="button" class="kebab-btn" data-action-menu-trigger="true" data-menu-id="share-direct-file-actions-<%= cv.id %>" aria-label="File actions">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                      <circle cx="12" cy="5" r="1.8"></circle>
                      <circle cx="12" cy="12" r="1.8"></circle>
                      <circle cx="12" cy="19" r="1.8"></circle>
                    </svg>
                  </button>

                  <div id="share-direct-file-actions-<%= cv.id %>" class="kebab-menu hidden">
                  <% if preview_url.present? %>
                    <button type="button"
                            class="kebab-item share-preview-btn"
                            data-preview="<%= preview_url %>"
                            data-download="<%= download_url %>"
                            data-preview-kind="<%= content_type %>"
                            data-preview-title="<%= display_name %>">
                      Preview
                    </button>
                  <% end %>
                  <% if download_url.present? %>
                    <a class="kebab-item" href="<%= download_url %>" data-turbo="false" data-turbo-frame="_top">Download</a>
                  <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <%# Files inside selected folder %>
          <% if (@cvs || []).any? %>
            <% (@cvs || []).each do |cv| %>
              <% blob = cv.file&.blob %>
              <% next unless blob %>

              <% display_name = cv.title.presence || cv.file.filename.to_s %>
              <% ext = cv.file.filename.extension.to_s.upcase %>
              <% type_label = ext.present? ? ext : "FILE" %>
              <% size_bytes = blob.byte_size.to_i %>
              <% content_type = blob.content_type.to_s %>

              <% preview_url  = @share_link.allow_preview?  ? file_preview_share_link_path(@share_link, cv_id: cv.id) : nil %>
              <% download_url = @share_link.allow_download? ? file_download_share_link_path(@share_link, cv_id: cv.id) : nil %>

              <div class="drive-row cv-row clickable-row"
                   data-kind="file"
                   data-preview="<%= preview_url || "" %>"
                   data-download="<%= download_url || "" %>"
                   data-preview-kind="<%= content_type %>"
                   data-preview-title="<%= display_name %>">

                <div class="col-cv-check">
                  <input class="cv-check" type="checkbox" value="<%= cv.id %>" />
                </div>

                <div class="col-cv-name">
                  <div class="file-line">
                    <%= file_icon_tag(cv.file, content_type: content_type) %>

                    <div class="file-text">
                      <div class="file-name"><%= display_name %></div>
                      <div class="file-sub"><%= cv.file.filename %></div>
                    </div>
                  </div>
                </div>

                <div class="col-cv-type"><span class="pill"><%= type_label %></span></div>
                <div class="col-cv-size"><span class="muted size-num" data-size-text><%= size_bytes %></span></div>
                <div class="col-cv-modified"><span class="muted"><%= cv.updated_at.strftime("%b %d, %Y %H:%M") %></span></div>

                <div class="col-cv-actions">
                  <div class="kebab-wrap">
                    <button type="button" class="kebab-btn" data-action-menu-trigger="true" data-menu-id="share-folder-file-actions-<%= cv.id %>" aria-label="File actions">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                        <circle cx="12" cy="5" r="1.8"></circle>
                        <circle cx="12" cy="12" r="1.8"></circle>
                        <circle cx="12" cy="19" r="1.8"></circle>
                      </svg>
                    </button>

                    <div id="share-folder-file-actions-<%= cv.id %>" class="kebab-menu hidden">
                    <% if preview_url.present? %>
                      <button type="button"
                              class="kebab-item share-preview-btn"
                              data-preview="<%= preview_url %>"
                              data-download="<%= download_url %>"
                              data-preview-kind="<%= content_type %>"
                              data-preview-title="<%= display_name %>">
                        Preview
                      </button>
                    <% end %>
                    <% if download_url.present? %>
                      <a class="kebab-item" href="<%= download_url %>" data-turbo="false" data-turbo-frame="_top">Download</a>
                    <% end %>
                    </div>
                  </div>
                </div>

              </div>
            <% end %>
          <% elsif (@subfolders || []).empty? && direct_files.empty? %>
            <div class="muted share-empty-copy">This folder is empty.</div>
          <% end %>

        </div>
      </div>
    </div>
  <% end %>

</div>

<%= render "shared/file_preview_modal" %>

<script>
  function initShareLinkShow() {
    // Turbo-safe: remove old listeners
    if (window.__shareShowAbort) window.__shareShowAbort.abort();
    window.__shareShowAbort = new AbortController();
    const { signal } = window.__shareShowAbort;

    function humanSize(bytes) {
      const units = ["B","KB","MB","GB","TB"];
      let b = Number(bytes || 0);
      let i = 0;
      while (b >= 1024 && i < units.length - 1) { b = b / 1024; i++; }
      return (i === 0 ? b.toFixed(0) : b.toFixed(1)) + " " + units[i];
    }

    // Format sizes
    document.querySelectorAll("[data-size-text]").forEach((el) => {
      const raw = parseInt(el.textContent || "0", 10);
      el.textContent = humanSize(raw);
    });

    const previewOverlay = document.getElementById("file-preview-overlay");
    const previewTitle = document.getElementById("file-preview-title");
    const previewDownload = document.getElementById("file-preview-download");
    const previewClose = document.getElementById("file-preview-close");
    const previewFrame = document.getElementById("file-preview-frame");
    const previewVideo = document.getElementById("file-preview-video");
    const previewImage = document.getElementById("file-preview-image");
    const previewAudio = document.getElementById("file-preview-audio");
    const previewFallback = document.getElementById("file-preview-fallback");
    const previewOpenNew = document.getElementById("file-preview-open-new");
    const previewDownloadFallback = document.getElementById("file-preview-download-fallback");
    const previewPrev = document.getElementById("file-preview-prev");
    const previewNext = document.getElementById("file-preview-next");
    let activePreviewIndex = -1;

    function previewEntries() {
      return Array.from(document.querySelectorAll(".drive-row[data-kind='file']"))
        .map((row) => ({
          previewUrl: row.getAttribute("data-preview"),
          downloadUrl: row.getAttribute("data-download"),
          title: row.getAttribute("data-preview-title"),
          contentType: row.getAttribute("data-preview-kind")
        }))
        .filter((entry) => ["image", "video"].includes(previewKind(entry.contentType)) && entry.previewUrl);
    }

    function updatePreviewNavigation() {
      const galleryEntries = previewEntries();
      const hasActiveMedia = activePreviewIndex >= 0 && galleryEntries.length > 0;

      [previewPrev, previewNext].forEach((button) => {
        if (!button) return;
        button.hidden = !hasActiveMedia;
        button.disabled = !hasActiveMedia || galleryEntries.length < 2;
      });
    }

    function hidePreviewNodes() {
      [previewFrame, previewVideo, previewImage, previewAudio, previewFallback].forEach((node) => {
        if (!node) return;
        node.hidden = true;
      });

      if (previewFrame) previewFrame.src = "";
      if (previewVideo) {
        previewVideo.pause();
        previewVideo.removeAttribute("src");
        previewVideo.load();
      }
      if (previewImage) previewImage.removeAttribute("src");
      if (previewAudio) {
        previewAudio.pause();
        previewAudio.removeAttribute("src");
        previewAudio.load();
      }
    }

    function previewKind(contentType) {
      const type = String(contentType || "").toLowerCase();
      if (type.includes("pdf")) return "pdf";
      if (type.startsWith("video/")) return "video";
      if (type.startsWith("image/")) return "image";
      if (type.startsWith("audio/")) return "audio";
      return "fallback";
    }

    function closePreviewModal() {
      hidePreviewNodes();
      activePreviewIndex = -1;
      updatePreviewNavigation();
      if (previewOverlay) previewOverlay.hidden = true;
    }

    function openPreviewModal({ previewUrl, downloadUrl, title, contentType }) {
      if (!previewOverlay || !previewUrl) {
        if (previewUrl) window.open(previewUrl, "_blank", "noopener");
        return;
      }

      const galleryEntries = previewEntries();
      const nextIndex = galleryEntries.findIndex((entry) => entry.previewUrl === previewUrl);
      activePreviewIndex = ["image", "video"].includes(previewKind(contentType)) ? nextIndex : -1;

      hidePreviewNodes();
      if (previewTitle) previewTitle.textContent = title || "File preview";
      if (previewDownload) previewDownload.href = downloadUrl || previewUrl;
      if (previewOpenNew) previewOpenNew.href = previewUrl;
      if (previewDownloadFallback) previewDownloadFallback.href = downloadUrl || previewUrl;

      switch (previewKind(contentType)) {
        case "pdf":
          if (previewFrame) {
            previewFrame.src = previewUrl;
            previewFrame.hidden = false;
          }
          break;
        case "video":
          if (previewVideo) {
            previewVideo.src = previewUrl;
            previewVideo.hidden = false;
          }
          break;
        case "image":
          if (previewImage) {
            previewImage.src = previewUrl;
            previewImage.hidden = false;
          }
          break;
        case "audio":
          if (previewAudio) {
            previewAudio.src = previewUrl;
            previewAudio.hidden = false;
          }
          break;
        default:
          if (previewFallback) previewFallback.hidden = false;
      }

      updatePreviewNavigation();
      previewOverlay.hidden = false;
    }

    function stepPreview(direction) {
      const galleryEntries = previewEntries();
      if (activePreviewIndex < 0 || galleryEntries.length === 0) return;

      const nextIndex = (activePreviewIndex + direction + galleryEntries.length) % galleryEntries.length;
      const nextEntry = galleryEntries[nextIndex];
      if (!nextEntry) return;

      openPreviewModal(nextEntry);
    }

    if (previewClose) previewClose.addEventListener("click", closePreviewModal, { signal });
    if (previewPrev) previewPrev.addEventListener("click", () => stepPreview(-1), { signal });
    if (previewNext) previewNext.addEventListener("click", () => stepPreview(1), { signal });
    if (previewOverlay) {
      previewOverlay.addEventListener("click", (event) => {
        if (event.target === previewOverlay) closePreviewModal();
      }, { signal });
    }

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && previewOverlay && !previewOverlay.hidden) closePreviewModal();
      if (event.key === "ArrowLeft" && previewOverlay && !previewOverlay.hidden) stepPreview(-1);
      if (event.key === "ArrowRight" && previewOverlay && !previewOverlay.hidden) stepPreview(1);
    }, { signal });

    document.querySelectorAll("[data-go-back]").forEach((button) => {
      button.addEventListener("click", () => {
        const referrer = document.referrer || "";
        const sameOriginReferrer = referrer.startsWith(window.location.origin);
        if (window.history.length > 1 && sameOriginReferrer) {
          window.history.back();
          return;
        }

        const fallbackUrl = button.getAttribute("data-fallback-url");
        if (fallbackUrl) window.location.href = fallbackUrl;
      }, { signal });
    });

    // Copy link
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      if (btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";

      btn.addEventListener("click", async () => {
        const text = btn.getAttribute("data-copy");
        const copied = typeof window.copyTextToClipboard === "function"
          ? await window.copyTextToClipboard(text)
          : false;
        if (!copied) return;
        const old = btn.textContent;
        btn.textContent = "Copied";
        setTimeout(() => (btn.textContent = old), 900);
      }, { signal });
    });

    // Row selection
    const selectAll = document.getElementById("select-all");
    const bulkBar = document.getElementById("bulk-actions");
    const bulkOpen = document.getElementById("bulk-open");
    const bulkPreview = document.getElementById("bulk-preview");
    const bulkDownload = document.getElementById("bulk-download");
    const bulkClear = document.getElementById("bulk-clear");

    const fileChecks = Array.from(document.querySelectorAll(".cv-check"));
    const folderChecks = Array.from(document.querySelectorAll(".folder-check"));

    // stop click on checkbox from triggering row click logic twice
    [...fileChecks, ...folderChecks].forEach((cb) => {
      cb.addEventListener("click", (e) => e.stopPropagation(), { signal });
    });

    function selectedRows() {
      const rows = [];
      fileChecks.forEach((cb) => {
        if (cb.checked) {
          const row = cb.closest(".drive-row");
          if (row) rows.push(row);
        }
      });
      folderChecks.forEach((cb) => {
        if (cb.checked) {
          const row = cb.closest(".drive-row");
          if (row) rows.push(row);
        }
      });
      return rows;
    }

    function updateBulk() {
      const rows = selectedRows();
      const fileRows = rows.filter((row) => row.getAttribute("data-kind") === "file");
      const downloadableRows = rows.filter((row) => row.getAttribute("data-download"));
      const any = rows.length > 0;

      if (bulkBar) bulkBar.style.display = any ? "flex" : "none";
      if (bulkOpen) bulkOpen.hidden = rows.length !== 1;
      if (bulkPreview) bulkPreview.hidden = fileRows.length !== 1 || rows.length !== 1;
      if (bulkDownload) bulkDownload.hidden = !any || downloadableRows.length !== rows.length;

      if (selectAll) {
        const all = [...fileChecks, ...folderChecks];
        selectAll.checked = all.length > 0 && all.every((c) => c.checked);
      }
    }

    if (selectAll) {
      selectAll.addEventListener("change", () => {
        const val = selectAll.checked;
        fileChecks.forEach((c) => (c.checked = val));
        folderChecks.forEach((c) => (c.checked = val));
        updateBulk();
      }, { signal });
    }

    fileChecks.forEach((c) => c.addEventListener("change", updateBulk, { signal }));
    folderChecks.forEach((c) => c.addEventListener("change", updateBulk, { signal }));

    // Click row opens item; checkboxes remain the selection mechanism
    document.querySelectorAll(".drive-row").forEach((row) => {
      // only rows that have a checkbox
      const cb = row.querySelector(".cv-check, .folder-check");
      if (!cb) return;

      row.addEventListener("click", (e) => {
        if (e.target.closest("a, button, input, label, form")) return;
        if (e.target.closest(".col-cv-actions")) return;

        const kind = row.getAttribute("data-kind");

        if (kind === "folder") {
          const url = row.getAttribute("data-open");
          if (url) window.location.href = url;
          return;
        }

        // file
        const url = row.getAttribute("data-preview");
        openPreviewModal({
          previewUrl: url,
          downloadUrl: row.getAttribute("data-download"),
          title: row.getAttribute("data-preview-title"),
          contentType: row.getAttribute("data-preview-kind")
        });
      }, { signal });
    });

    document.querySelectorAll(".share-preview-btn").forEach((button) => {
      button.addEventListener("click", (event) => {
        event.preventDefault();
        openPreviewModal({
          previewUrl: button.dataset.preview,
          downloadUrl: button.dataset.download,
          title: button.dataset.previewTitle,
          contentType: button.dataset.previewKind
        });
      }, { signal });
    });

    function openMany(urls, newTab) {
      const unique = Array.from(new Set(urls.filter(Boolean)));
      unique.forEach((u, idx) => {
        // small stagger helps popup blockers a bit
        setTimeout(() => {
          if (newTab) window.open(u, "_blank", "noopener");
          else window.location.href = u;
        }, idx * 120);
      });
    }

    if (bulkOpen) {
      bulkOpen.addEventListener("click", (e) => {
        e.preventDefault();
        const rows = selectedRows();
        if (rows.length !== 1) return;

        const row = rows[0];
        if (row.getAttribute("data-kind") === "folder") {
          const folderUrl = row.getAttribute("data-open");
          if (folderUrl) window.location.href = folderUrl;
          return;
        }

        const previewUrl = row.getAttribute("data-preview");
        if (previewUrl) window.open(previewUrl, "_blank", "noopener");
      }, { signal });
    }

    if (bulkPreview) {
      bulkPreview.addEventListener("click", (e) => {
        e.preventDefault();
        const rows = selectedRows();
        const fileRows = rows.filter((row) => row.getAttribute("data-kind") === "file");
        if (rows.length !== 1 || fileRows.length !== 1) return;

        const fileRow = fileRows[0];
        openPreviewModal({
          previewUrl: fileRow.getAttribute("data-preview"),
          downloadUrl: fileRow.getAttribute("data-download"),
          title: fileRow.getAttribute("data-preview-title"),
          contentType: fileRow.getAttribute("data-preview-kind")
        });
      }, { signal });
    }

    if (bulkDownload) {
      bulkDownload.addEventListener("click", (e) => {
        e.preventDefault();
        const rows = selectedRows();
        const downloadableRows = rows.filter((row) => row.getAttribute("data-download"));
        if (downloadableRows.length === 0 || downloadableRows.length !== rows.length) return;

        const downloads = downloadableRows.map((row) => row.getAttribute("data-download")).filter(Boolean);
        // downloads happen by navigation/new tabs
        openMany(downloads, true);
      }, { signal });
    }

    if (bulkClear) {
      bulkClear.addEventListener("click", (e) => {
        e.preventDefault();
        fileChecks.forEach((c) => (c.checked = false));
        folderChecks.forEach((c) => (c.checked = false));
        if (selectAll) selectAll.checked = false;
        updateBulk();
      }, { signal });
    }

    updateBulk();
  }

  document.addEventListener("turbo:load", initShareLinkShow);
  document.addEventListener("DOMContentLoaded", initShareLinkShow);

  document.addEventListener("turbo:before-cache", () => {
    if (window.__shareShowAbort) window.__shareShowAbort.abort();
    window.__shareShowAbort = null;
    const previewOverlay = document.getElementById("file-preview-overlay");
    if (previewOverlay) previewOverlay.hidden = true;
  });
</script>
