<div class="dashboard-page" data-share-links-index>

  <% if @share_links.any? %>
    <div class="share-links-section-title">Links you created</div>
    <div class="drive-card">
      <div class="drive-scroll">
        <div class="drive-list share-links-list">

          <div class="drive-header">
            <div class="col-folder">Folders</div>
            <div class="col-url">Share link</div>
            <div class="col-expires">Expires</div>
            <div class="col-created">Created</div>
            <div class="col-actions">Actions</div>
          </div>

          <% @share_links.each do |link| %>
            <% folders = link.respond_to?(:all_folders) ? link.all_folders : [] %>
            <% first_folder = folders.first || link.folder %>
            <% folder_count = folders.size %>
            <% share_url = public_share_url(link.token) %>
            <% share_targets = link.share_targets %>

            <div class="drive-row share-row">
              <div class="col-folder">
                <% if first_folder %>
                  <%= link_to folder_path(first_folder), class: "folder-link" do %>
                    <%= folder_icon_tag %>
                    <span class="folder-name">
                      <%= first_folder.name %>
                      <% if folder_count > 1 %>
                        <span class="muted share-links-folder-extra">(+<%= folder_count - 1 %>)</span>
                      <% end %>
                    </span>
                  <% end %>
                <% else %>
                  <span class="muted">No folder</span>
                <% end %>

                <div class="muted share-links-targets">
                  <% if share_targets.one? && share_targets.first[:kind] == :public %>
                    Anyone with the link
                  <% else %>
                    <%= share_targets.map { |target| "#{target[:label]} (#{target[:permission] == "editor" ? "Can edit" : "Can view"})" }.join(", ") %>
                  <% end %>
                </div>
              </div>

              <div class="col-url">
                <div class="url-line">
                  <a class="url-text" href="<%= share_url %>" target="_blank" rel="noopener"><%= share_url %></a>
                </div>
              </div>

              <div class="col-expires">
                <span class="muted">
                  <% if link.expires_at.nil? %>
                    Never
                  <% elsif link.expires_at < Time.current %>
                    Expired
                  <% else %>
                    <%= link.expires_at.strftime("%b %d, %Y %H:%M") %>
                  <% end %>
                </span>
              </div>

              <div class="col-created">
                <span class="muted"><%= link.created_at.strftime("%b %d, %Y %H:%M") %></span>
              </div>

              <div class="col-actions">
                <div class="kebab-wrap">
                  <button type="button" class="kebab-btn" data-action-menu-trigger="true" data-menu-id="share-link-actions-<%= link.id %>" aria-label="Share link actions">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                      <circle cx="12" cy="5" r="1.8"></circle>
                      <circle cx="12" cy="12" r="1.8"></circle>
                      <circle cx="12" cy="19" r="1.8"></circle>
                    </svg>
                  </button>

                  <div id="share-link-actions-<%= link.id %>" class="kebab-menu hidden">
                    <button type="button" class="kebab-item copy-btn" data-copy="<%= share_url %>">Copy</button>

                    <%= link_to "Open",
                      public_share_path(link.token),
                      target: "_blank",
                      rel: "noopener",
                      class: "kebab-item" %>

                    <%= button_to "Delete",
                      share_link_path(link),
                      method: :delete,
                      data: { confirm: "Delete this share link?" },
                      class: "kebab-item danger",
                      form: { class: "inline-form" } %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

        </div>
      </div>
    </div>
    <%= render "shared/pagination",
      total_count: @share_links.total_count,
      page: @page,
      per_page: @per_page,
      base_params: request.query_parameters %>
  <% else %>
    <div class="drive-card share-links-empty-card">
      <div class="muted">No share links yet.</div>
    </div>
  <% end %>

  <div class="share-links-spacer"></div>

  <% if @received_share_links.any? %>
    <div class="share-links-section-title">Shared with you</div>
    <div class="drive-card">
      <div class="drive-scroll">
        <div class="drive-list share-links-list">

          <div class="drive-header">
            <div class="col-folder">Items</div>
            <div class="col-url">From</div>
            <div class="col-expires">Expires</div>
            <div class="col-created">Created</div>
            <div class="col-actions">Actions</div>
          </div>

          <% @received_share_links.each do |link| %>
            <% folders = link.respond_to?(:all_folders) ? link.all_folders : [] %>
            <% files = link.cvs.to_a %>
            <% share_url = public_share_url(link.token) %>
            <% item_label =
              if folders.any?
                label = folders.first.name
                folders.size > 1 ? "#{label} (+#{folders.size - 1})" : label
              elsif files.any?
                label = files.first.title.presence || files.first.file.filename.to_s
                files.size > 1 ? "#{label} (+#{files.size - 1})" : label
              else
                "Shared items"
              end %>

            <div class="drive-row share-row">
              <div class="col-folder">
                <span class="folder-name"><%= item_label %></span>
              </div>

              <div class="col-url">
                <span class="muted"><%= link.user&.email || "Unknown sender" %></span>
              </div>

              <div class="col-expires">
                <span class="muted">
                  <% if link.expires_at.nil? %>
                    Never
                  <% elsif link.expires_at < Time.current %>
                    Expired
                  <% else %>
                    <%= link.expires_at.strftime("%b %d, %Y %H:%M") %>
                  <% end %>
                </span>
              </div>

              <div class="col-created">
                <span class="muted"><%= link.created_at.strftime("%b %d, %Y %H:%M") %></span>
              </div>

              <div class="col-actions">
                <div class="kebab-wrap">
                  <button type="button" class="kebab-btn" data-action-menu-trigger="true" data-menu-id="received-share-link-actions-<%= link.id %>" aria-label="Received share link actions">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                      <circle cx="12" cy="5" r="1.8"></circle>
                      <circle cx="12" cy="12" r="1.8"></circle>
                      <circle cx="12" cy="19" r="1.8"></circle>
                    </svg>
                  </button>

                  <div id="received-share-link-actions-<%= link.id %>" class="kebab-menu hidden">
                    <button type="button" class="kebab-item copy-btn" data-copy="<%= share_url %>">Copy</button>
                    <%= link_to "Open",
                      public_share_path(link.token),
                      target: "_blank",
                      rel: "noopener",
                      class: "kebab-item" %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

        </div>
      </div>
    </div>
    <%= render "shared/pagination",
      total_count: @received_share_links.total_count,
      page: @received_page,
      per_page: @received_per_page,
      page_param: :received_page,
      base_params: request.query_parameters %>
  <% else %>
    <div class="drive-card share-links-empty-card">
      <div class="muted">Nothing has been shared with you yet.</div>
    </div>
  <% end %>

</div>
