<div class="dashboard-page" data-share-links-new>

  <div class="drive-page-head">
    <div class="drive-head-left">
      <h1 class="share-links-new-title">Create share link</h1>
      <div class="muted share-links-new-subtitle">
        Share a whole folder or only selected files (expires in 24h)
      </div>
    </div>
  </div>

  <!-- Step 1: Pick folder -->
  <div class="drive-card share-links-new-card">
    <form action="<%= new_share_link_path %>" method="get" class="share-links-new-inline-form">
      <div class="share-links-new-toolbar">
        <select name="folder_id" class="drive-select" required>
          <option value="">Select a folder…</option>
          <% @folders.each do |f| %>
            <option value="<%= f.id %>" <%= "selected" if defined?(@folder) && @folder&.id == f.id %>><%= f.name %></option>
          <% end %>
        </select>

        <button type="submit" class="btn secondary">Load files</button>
        <%= link_to "Back", share_links_path, class: "btn secondary" %>
      </div>
    </form>
  </div>

  <% if defined?(@folder) && @folder.present? %>

    <!-- Option A: Share whole folder -->
    <div class="share-links-new-section">
      <div class="drive-card share-links-new-card">
        <div class="share-links-new-split">
          <div>
            <div class="share-links-new-section-title">Share whole folder</div>
            <div class="muted">Anyone with the link can view all files in “<%= @folder.name %>”.</div>
          </div>

          <%= form_with url: share_links_path, method: :post, local: true do %>
            
            <button type="submit" class="btn primary">Create folder link</button>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Option B: Share selected files -->
    <div class="share-links-new-section-label">Or share selected files</div>

    <div class="drive-card share-links-new-list-card">
      <div class="drive-scroll">
        <div class="drive-list select-files-list">

          <div class="drive-header">
            <div class="col-check">
              <input type="checkbox" id="select-all" />
            </div>
            <div class="col-name">Name</div>
            <div class="col-type">Type</div>
            <div class="col-size">Size</div>
            <div class="col-modified">Last modified</div>
          </div>

          <%= form_with url: share_links_path, method: :post, local: true, id: "share-selected-form" do %>
            

            <% @cvs.each do |cv| %>
              <% blob = cv.file&.blob %>
              <% display_name = cv.title.presence || cv.file.filename.to_s %>
              <% ext = cv.file.filename.extension.to_s.upcase %>
              <% type_label = ext.present? ? ext : "FILE" %>
              <% size_bytes = blob&.byte_size.to_i %>

              <div class="drive-row file-row">
                <div class="col-check">
                  <input class="cv-check" type="checkbox" name="cv_ids[]" value="<%= cv.id %>" />
                </div>

                <div class="col-name">
                  <div class="file-line">
                    <%= file_icon_tag(cv.file, size: 16) %>

                    <div class="file-text">
                      <div class="file-name"><%= display_name %></div>
                      <div class="file-sub"><%= cv.file.filename %></div>
                    </div>
                  </div>
                </div>

                <div class="col-type">
                  <span class="pill"><%= type_label %></span>
                </div>

                <div class="col-size">
                  <span class="muted size-num" data-size-text><%= size_bytes %></span>
                </div>

                <div class="col-modified">
                  <span class="muted"><%= cv.updated_at.strftime("%b %d, %Y %H:%M") %></span>
                </div>
              </div>
            <% end %>

            <div class="share-links-new-actions">
              <button type="submit" class="btn primary" id="share-selected-btn" disabled>
                Create link for selected
              </button>
            </div>
          <% end %>

        </div>
      </div>
    </div>

  <% end %>

</div>
