<div class="dashboard-page">
  <div class="drive-page-head">
    <div class="profile-page-title">
      <h2>Ratings</h2>
      <p>Review feedback and moderation activity across shared files.</p>
    </div>
  </div>

  <% if @ratings.any? %>
    <div class="drive-card ratings-card">
      <div class="drive-scroll">
        <table class="dashboard-table ratings-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>CV</th>
              <th>User</th>
              <th>Stars</th>
              <th>Created At</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @ratings.each do |rating| %>
              <tr>
                <td><%= rating.id %></td>
                <td><%= rating.cv&.title || "Untitled CV" %></td>
                <td><%= rating.user&.email || "Unknown user" %></td>
                <td><%= "★" * rating.stars %></td>
                <td><%= rating.created_at.strftime("%b %d, %Y") %></td>
                <td>
                  <%= link_to "Delete", rating_path(rating), method: :delete, data: { confirm: "Are you sure?" }, class: "btn secondary xsmall" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="ratings-pagination">
      <%= paginate @ratings %>
    </div>
  <% else %>
    <div class="drive-card ratings-card">
      <p class="empty-message">No ratings yet.</p>
    </div>
  <% end %>
</div>
