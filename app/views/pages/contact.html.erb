<% support_email = ENV["SUPPORT_EMAIL"].presence || "support@#{ENV.fetch("APP_HOST", "cvshare.local")}" %>
<div class="dashboard-page content-page">
  <h2>Contact</h2>
  <p class="muted content-page-copy">
    For support, account questions, or business inquiries, use the contact details below.
  </p>
  <div class="content-page-meta">
    <div><strong>Email:</strong> <%= mail_to support_email %></div>
    <div><strong>Response time:</strong> Typically within 1 business day</div>
  </div>
</div>
