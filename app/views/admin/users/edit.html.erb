<div class="admin-shell">
  <div class="admin-section-head">
    <div>
      <div class="admin-eyebrow">Account Editor</div>
      <h1 class="admin-title">Edit user</h1>
      <div class="admin-subtitle">Update account details, permissions, and recovery actions for <%= @user.email %>.</div>
    </div>

    <div class="admin-hero-actions">
      <%= link_to "Back", admin_users_path, class: "btn secondary" %>
    </div>
  </div>

  <div class="admin-edit-grid">
    <div class="admin-panel admin-panel-form">
      <div class="admin-form-intro">
        <div class="admin-card-kicker">Profile</div>
        <div class="admin-card-title">Account settings</div>
        <div class="admin-form-copy">Change user identity, adjust admin access, or set a new password directly.</div>
      </div>
      <%= form_with(model: @user, url: admin_user_path(@user), method: :patch, local: true) do |f| %>
        <div class="form-row">
          <label class="label">Name</label>
          <%= f.text_field :name, class: "input" %>
        </div>

        <div class="form-row">
          <label class="label">Email</label>
          <%= f.email_field :email, class: "input" %>
        </div>

        <div class="form-row">
          <label class="label">Role</label>
          <label class="admin-checkbox-row">
            <%= f.check_box :admin %>
            <span>Allow access to the admin area</span>
          </label>
        </div>

        <div class="form-row">
          <label class="label">New password</label>
          <%= f.password_field :password, class: "input", autocomplete: "new-password" %>
        </div>

        <div class="form-row">
          <label class="label">Confirm new password</label>
          <%= f.password_field :password_confirmation, class: "input", autocomplete: "new-password" %>
        </div>

        <div class="admin-form-actions">
          <%= f.submit "Save changes", class: "btn primary" %>
          <%= link_to "Cancel", admin_users_path, class: "btn secondary" %>
        </div>
      <% end %>
    </div>

    <div class="admin-side-stack">
      <div class="admin-panel admin-panel-form">
        <div class="admin-card-kicker">Status</div>
        <div class="admin-card-title">User status</div>
        <div class="admin-side-meta">
          <div>
            <span class="admin-side-label">Current role</span>
            <span class="admin-badge <%= @user.admin? ? 'is-admin' : 'is-user' %>">
              <%= @user.admin? ? "Admin" : "User" %>
            </span>
          </div>
          <div>
            <span class="admin-side-label">Account status</span>
            <span class="admin-badge <%= @user.suspended? ? 'is-suspended' : 'is-active' %>">
              <%= @user.suspended? ? "Suspended" : "Active" %>
            </span>
          </div>
          <div>
            <span class="admin-side-label">Joined</span>
            <span class="admin-side-value"><%= @user.created_at.strftime("%B %-d, %Y") %></span>
          </div>
        </div>
      </div>

      <div class="admin-panel admin-panel-form">
        <div class="admin-card-kicker">Usage</div>
        <div class="admin-card-title">Workspace usage</div>
        <div class="admin-usage-grid">
          <div class="admin-usage-item">
            <span class="admin-side-label">Folders</span>
            <span class="admin-side-value"><%= @user_folders_count %></span>
          </div>
          <div class="admin-usage-item">
            <span class="admin-side-label">Files</span>
            <span class="admin-side-value"><%= @user_files_count %></span>
          </div>
          <div class="admin-usage-item">
            <span class="admin-side-label">Share links</span>
            <span class="admin-side-value"><%= @user_share_links_count %></span>
          </div>
          <div class="admin-usage-item">
            <span class="admin-side-label">Storage</span>
            <span class="admin-side-value"><%= format_bytes(@user_storage_bytes) %></span>
          </div>
        </div>
      </div>

      <div class="admin-panel admin-panel-form">
        <div class="admin-card-kicker">Recovery</div>
        <div class="admin-card-title">Admin actions</div>
        <div class="admin-side-actions">
          <%= button_to "Generate invite link", send_invite_admin_user_path(@user), method: :post, class: "btn secondary", form: { class: "admin-inline-form" } %>
          <%= button_to "Generate password reset link", reset_password_admin_user_path(@user), method: :post, class: "btn secondary", form: { class: "admin-inline-form" } %>
          <%= button_to (@user.suspended? ? "Reactivate user" : "Suspend user"), toggle_suspended_admin_user_path(@user), method: :patch, class: "btn #{@user.suspended? ? 'secondary' : 'danger'}", form: { class: "admin-inline-form" } %>
        </div>
      </div>
    </div>
  </div>
</div>
