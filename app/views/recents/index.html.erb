<div class="dashboard-page" data-recents-index>

  <div class="drive-page-head">
    <div class="drive-head-left">
      <h1 class="recents-title">Recents</h1>
      <div class="muted recents-subtitle">Recently modified files</div>
    </div>

    <div class="drive-head-right">
      <input id="recent-search" class="drive-input" type="text" placeholder="Search recents…" autocomplete="off" />
    </div>
  </div>

  <% if @recent_cvs.any? %>
    <div class="drive-card">
      <div class="drive-scroll">
        <div class="drive-list recents-list">

          <div class="drive-header">
            <div class="col-name">Name</div>
            <div class="col-type">Type</div>
            <div class="col-size">Size</div>
            <div class="col-location">Location</div>
            <div class="col-modified">Last modified</div>
            <div class="col-actions">Actions</div>
          </div>

          <% @recent_cvs.each do |cv| %>
            <% blob = cv.file&.blob %>
            <% display_name = cv.title.presence || cv.file.filename.to_s %>
            <% ext = cv.file.filename.extension.to_s.upcase %>
            <% type_label = ext.present? ? ext : "FILE" %>
            <% size_bytes = blob&.byte_size.to_i %>
            <% content_type = blob&.content_type.to_s %>
            <% folder = cv.folder %>

            <div class="drive-row recent-row"
                 data-name="<%= display_name.to_s.downcase %>"
                 data-type="<%= type_label.to_s.downcase %>"
                 data-preview="<%= rails_blob_path(cv.file, disposition: "inline") %>"
                 data-download="<%= rails_blob_path(cv.file, disposition: "attachment") %>"
                 data-preview-kind="<%= content_type %>"
                 data-preview-title="<%= display_name %>">

              <div class="col-name">
                <div class="file-line">
                  <%= file_icon_tag(cv.file, content_type: content_type, size: 16) %>

                  <div class="file-text">
                    <div class="file-name"><%= display_name %></div>
                    <div class="file-sub"><%= cv.file.filename %></div>
                  </div>
                </div>
              </div>

              <div class="col-type">
                <span class="pill"><%= type_label %></span>
              </div>

              <div class="col-size">
                <span class="muted size-num" data-size-text><%= size_bytes %></span>
              </div>

              <div class="col-location">
                <% if folder.present? %>
                  <%= link_to folder.name, folder_path(folder), class: "location-link" %>
                <% else %>
                  <span class="muted">—</span>
                <% end %>
              </div>

              <div class="col-modified">
                <span class="muted"><%= cv.updated_at.strftime("%b %d, %Y %H:%M") %></span>
              </div>

              <div class="col-actions">
                <div class="kebab-wrap">
                  <button type="button" class="kebab-btn" data-action-menu-trigger="true" data-menu-id="recent-actions-<%= cv.id %>" aria-label="File actions">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                      <circle cx="12" cy="5" r="1.8"></circle>
                      <circle cx="12" cy="12" r="1.8"></circle>
                      <circle cx="12" cy="19" r="1.8"></circle>
                    </svg>
                  </button>

                  <div id="recent-actions-<%= cv.id %>" class="kebab-menu hidden">
                    <button type="button"
                      class="kebab-item preview-file-btn"
                      data-preview="<%= rails_blob_path(cv.file, disposition: "inline") %>"
                      data-download="<%= rails_blob_path(cv.file, disposition: "attachment") %>"
                      data-preview-kind="<%= content_type %>"
                      data-preview-title="<%= display_name %>">
                      Preview
                    </button>

                    <%= link_to "Download",
                      rails_blob_path(cv.file, disposition: "attachment"),
                      class: "kebab-item" %>

                    <% if folder.present? %>
                      <button type="button"
                        class="kebab-item file-rename-btn"
                        data-file-name="<%= display_name %>"
                        data-rename-url="<%= folder_cv_path(folder, cv) %>">
                        Rename
                      </button>

                      <%= link_to "Open folder",
                        folder_path(folder),
                        class: "kebab-item" %>
                    <% end %>
                  </div>
                </div>
              </div>

            </div>
          <% end %>

        </div>
      </div>
    </div>

    <%= render "shared/pagination",
      total_count: @recent_cvs.total_count,
      page: @page,
      per_page: @per_page,
      base_params: request.query_parameters %>

    <div id="recent-no-results" class="no-results" hidden>
      No recent files match your search.
    </div>

  <% else %>
    <p class="empty-message">Nothing recent yet.</p>
  <% end %>

  <%= render "shared/file_preview_modal" %>

  <div id="rename-file-overlay" class="overlay" style="display:none;">
    <div class="modal-card">
      <div class="modal-head">
        <h3 class="modal-title">Rename file</h3>
        <button type="button" id="close-rename-file" class="btn secondary xsmall">Close</button>
      </div>

      <div class="folder-show-modal-body">
        <%= form_with url: "#", method: :patch, local: true, id: "rename-file-form" do %>
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

          <div class="muted folder-show-modal-label">New name</div>
          <input id="rename-file-input"
                 name="cv[title]"
                 type="text"
                 required
                 class="folder-show-modal-input">

          <div class="modal-actions">
            <button type="button" id="cancel-rename-file" class="btn secondary">Cancel</button>
            <button type="submit" class="btn primary">Rename</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>
