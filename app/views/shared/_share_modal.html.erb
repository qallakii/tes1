<div id="share-modal" class="share-modal-overlay" data-share-modal hidden>
  <div class="share-modal-card">
    <div class="share-modal-head">
      <h3 class="share-modal-title">Share items</h3>
      <button type="button" class="btn secondary xsmall" data-share-close>Close</button>
    </div>

    <div class="muted share-modal-subtitle">
      Choose how long the link should stay active and who can open it.
    </div>

    <div class="share-modal-body">
      <div data-share-form-view>
        <label class="share-modal-label" for="share-expires-at">Expiry date</label>
        <input id="share-expires-at" class="drive-input share-modal-input" type="datetime-local" data-share-expires>

        <div class="share-modal-label">Who can access this link?</div>
        <div class="share-modal-options">
          <label class="share-modal-option">
            <input type="radio" name="share_audience" value="anyone" checked data-share-audience>
            <span>Anyone with the link</span>
          </label>

          <label class="share-modal-option">
            <input type="radio" name="share_audience" value="specific_people" data-share-audience>
            <span>Specific people</span>
          </label>
        </div>

        <div class="share-modal-emails" data-share-emails-wrap hidden>
          <label class="share-modal-label" for="share-emails">Email addresses</label>
          <textarea
            id="share-emails"
            class="drive-input share-modal-textarea"
            data-share-emails
            placeholder="Enter one or more user emails, separated by commas or new lines"></textarea>
          <div class="muted share-modal-help">
            Only existing registered users can be added.
          </div>
        </div>

        <div class="share-modal-permission-wrap" data-share-permission-wrap hidden>
          <div class="share-modal-label">Permission</div>
          <div class="share-modal-options share-modal-options-inline">
            <label class="share-modal-option">
              <input type="radio" name="share_permission" value="viewer" checked data-share-permission>
              <span>Can view</span>
            </label>

            <label class="share-modal-option">
              <input type="radio" name="share_permission" value="editor" data-share-permission>
              <span>Can edit</span>
            </label>
          </div>
          <div class="muted share-modal-help">
            Edit permission is only available for specific people on shared folders.
          </div>
        </div>

        <div class="share-modal-existing" data-share-existing-wrap hidden>
          <div class="share-modal-existing-head">
            <div class="share-modal-label">Currently shared with</div>
            <div class="muted share-modal-existing-state" data-share-existing-state>Loading…</div>
          </div>
          <ul class="share-modal-existing-list" data-share-existing-list></ul>
        </div>
      </div>

      <div data-share-result-view hidden>
        <div class="share-result-title">Share link created</div>
        <a class="share-result-url share-result-url-modal" href="#" target="_blank" rel="noopener" data-share-result-url></a>
      </div>
    </div>

    <div class="share-modal-actions">
      <button type="button" class="btn secondary" data-share-cancel>Cancel</button>
      <button type="button" class="btn secondary" data-share-copy hidden>Copy link</button>
      <button type="button" class="btn primary" data-share-confirm>Create share link</button>
    </div>
  </div>
</div>
