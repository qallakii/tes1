<div class="drive-side-section <%= local_assigns[:mobile] ? 'drive-mobile-nav-links' : '' %>">
  <%= link_to dashboard_path, class: "drive-side-link #{'active' if controller_name == 'folders' && action_name == 'index'}" do %>
    <span class="drive-side-ic" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M3.5 10.5 12 4l8.5 6.5"></path>
        <path d="M5.5 9.8V20h13V9.8"></path>
        <path d="M9.5 20v-6h5v6"></path>
      </svg>
    </span>
    <span>Home</span>
  <% end %>

  <%= link_to recents_path, class: "drive-side-link #{'active' if controller_name == 'recents'}" do %>
    <span class="drive-side-ic" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
        <circle cx="12" cy="12" r="8"></circle>
        <path d="M12 7.5v5l3.2 2"></path>
      </svg>
    </span>
    <span>Recents</span>
  <% end %>

  <%= link_to share_links_path, class: "drive-side-link #{'active' if controller_name == 'share_links'}" do %>
    <span class="drive-side-ic" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M9.5 14.5l5-5"></path>
        <path d="M8.7 10.8l-1.2 1.2a3.8 3.8 0 0 0 5.4 5.4l1.2-1.2"></path>
        <path d="M15.3 13.2l1.2-1.2a3.8 3.8 0 0 0-5.4-5.4L9.9 7.8"></path>
      </svg>
    </span>
    <span>Shared Links</span>
  <% end %>

  <%= link_to shared_with_me_path, class: "drive-side-link #{'active' if controller_name == 'shared_with_me'}" do %>
    <span class="drive-side-ic" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
        <circle cx="9" cy="8" r="3"></circle>
        <path d="M4 19a5 5 0 0 1 10 0"></path>
        <path d="M16.5 9.5a2.5 2.5 0 1 0 0-5"></path>
        <path d="M17 14.2a4.2 4.2 0 0 1 3 4"></path>
      </svg>
    </span>
    <span>Shared With Me</span>
  <% end %>

  <%= link_to profile_path, class: "drive-side-link #{'active' if controller_name == 'profiles'}" do %>
    <span class="drive-side-ic" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
        <circle cx="12" cy="8" r="3.5"></circle>
        <path d="M5.5 20a6.5 6.5 0 0 1 13 0"></path>
      </svg>
    </span>
    <span>Profile</span>
  <% end %>

  <% if current_user&.admin? %>
    <%= link_to admin_root_path, class: "drive-side-link #{'active' if controller_path.start_with?('admin/')}" do %>
      <span class="drive-side-ic" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M12 3.5l6.5 3.2v5.1c0 4.2-2.7 7.1-6.5 8.7-3.8-1.6-6.5-4.5-6.5-8.7V6.7z"></path>
          <path d="M9.3 12.2l1.8 1.8 3.8-4"></path>
        </svg>
      </span>
      <span>Admin</span>
    <% end %>
  <% end %>
</div>
