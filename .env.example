# Copy this file to .env for local development.
# Keep real secrets only in .env, Rails credentials, or your deployment secret store.

APP_HOST=localhost:3000
APP_PROTOCOL=http
MAILER_FROM=noreply@crewitdrive.local
SUPPORT_EMAIL=support@crewitdrive.local

PORT=3000
RAILS_MAX_THREADS=3
JOB_CONCURRENCY=1

# Optional local database password for production-like setups.
CV_SHARE_APP_DATABASE_PASSWORD=

# Optional SMTP settings. Leave blank to use file delivery in development.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=localhost
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_STARTTLS=true

# S3 storage. Required when config.active_storage.service is :amazon.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
AWS_S3_BUCKET=
# Optional local CA bundle for Ruby/OpenSSL certificate verification issues.
AWS_CA_BUNDLE=

# Production/deploy secret. Never commit the real value.
RAILS_MASTER_KEY=
